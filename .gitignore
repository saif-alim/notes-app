# Claude Code local overrides (agents/hooks/settings.json stay committed)
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock

# Bazel output symlinks
/bazel-*

# Rust
target/
**/*.rs.bk
# Cargo.lock is committed per-package — crate_universe needs it pinned.

# Swift / Xcode
.build/
.swiftpm/
DerivedData/
# Bazel-generated Xcode projects (regenerate with: bazel run //apps/ios:NotesXcodeProj)
apps/ios/*.xcodeproj
apps/ios/*.xcworkspace
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcuserstate
*.xcuserdatad/
Package.resolved

# Proto codegen (generated, checked via codegen rule)
**/gen/

# Android — native libs built by tools/build-android.sh (requires NDK + cargo-ndk)
apps/android/app/src/main/jniLibs/

# Android — Gradle build outputs
apps/android/.gradle/
apps/android/build/
apps/android/app/build/
apps/android/local.properties

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Env / secrets
.env
.env.*
!.env.example

# Logs / tmp
*.log
tmp/
