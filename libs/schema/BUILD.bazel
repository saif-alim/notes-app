load("@rules_proto//proto:defs.bzl", "proto_library")
load("@rules_rust_prost//:defs.bzl", "rust_prost_library")
load("@rules_swift//swift:swift.bzl", "swift_library")

# Single source of truth — notes.proto. Consumers import the generated
# language bindings below.
proto_library(
    name = "notes_proto",
    srcs = ["notes.proto"],
    visibility = ["//visibility:public"],
)

# Rust binding: generated by prost via rules_rust_prost.
# Produces pub mod notes::v1 { Note, ListNotesResponse, ... }.
rust_prost_library(
    name = "notes_rust_proto",
    proto = ":notes_proto",
    visibility = ["//visibility:public"],
)

# Swift binding: hand-written Codables mirroring notes.proto.
# See libs/schema/CLAUDE.md for the "add a message" workflow.
swift_library(
    name = "notes_swift_proto",
    srcs = glob(["Sources/NotesSchema/**/*.swift"]),
    module_name = "NotesSchema",
    visibility = ["//visibility:public"],
)
